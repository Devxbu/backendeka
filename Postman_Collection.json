{
	"info": {
		"_postman_id": "8b2d152a-9e7f-4b0d-9b5a-e7c5d6c5d6c5",
		"name": "EkaCS Backend Production API",
		"description": "Full production-ready API collection including all feature modules (Auth, Company, Project, Review, Content, Message, General, Notification) with Joi-validated request examples.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Register",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"studio@example.com\",\n    \"password\": \"Password123!\",\n    \"companyName\": \"Demo Studio\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/auth/register", "host": [ "{{base_url}}" ], "path": [ "auth", "register" ] }
					}
				},
				{
					"name": "Login",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"studio@example.com\",\n    \"password\": \"Password123!\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/auth/login", "host": [ "{{base_url}}" ], "path": [ "auth", "login" ] }
					}
				},
				{
					"name": "Refresh Token",
					"request": {
						"method": "POST",
						"header": [],
						"url": { "raw": "{{base_url}}/auth/refresh", "host": [ "{{base_url}}" ], "path": [ "auth", "refresh" ] }
					}
				},
				{
					"name": "Change Password",
					"request": {
						"auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{access_token}}", "type": "string" } ] },
						"method": "POST",
						"body": {
							"mode": "raw",
							"raw": "{\n    \"oldPassword\": \"Password123!\",\n    \"newPassword\": \"NewPassword123!\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/auth/change-password", "host": [ "{{base_url}}" ], "path": [ "auth", "change-password" ] }
					}
				}
			]
		},
		{
			"name": "Company",
			"item": [
				{
					"name": "Get Profile (Me)",
					"request": {
						"auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{access_token}}", "type": "string" } ] },
						"method": "GET",
						"url": { "raw": "{{base_url}}/company/me", "host": [ "{{base_url}}" ], "path": [ "company", "me" ] }
					}
				},
				{
					"name": "Update Profile",
					"request": {
						"auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{access_token}}", "type": "string" } ] },
						"method": "PUT",
						"body": {
							"mode": "formdata",
							"formdata": [
								{ "key": "name", "value": "Updated Studio Name", "type": "text" },
								{ "key": "bio", "value": "Modern design studio", "type": "text" },
								{ "key": "pfp", "type": "file", "src": "" },
								{ "key": "banner", "type": "file", "src": "" }
							]
						},
						"url": { "raw": "{{base_url}}/company/me", "host": [ "{{base_url}}" ], "path": [ "company", "me" ] }
					}
				},
				{
					"name": "Discover",
					"request": {
						"auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{access_token}}", "type": "string" } ] },
						"method": "GET",
						"url": { "raw": "{{base_url}}/company/discover?page=1&limit=20&country=USA", "host": [ "{{base_url}}" ], "path": [ "company", "discover" ], "query": [ { "key": "page", "value": "1" }, { "key": "limit", "value": "20" }, { "key": "country", "value": "USA" } ] }
					}
				}
			]
		},
		{
			"name": "Project",
			"item": [
				{
					"name": "Create Project Request",
					"request": {
						"auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{access_token}}", "type": "string" } ] },
						"method": "POST",
						"body": {
							"mode": "raw",
							"raw": "{\n    \"partnerId\": \"target_company_id\",\n    \"name\": \"Website Redesign\",\n    \"description\": \"Full redesign of our e-commerce platform.\",\n    \"budget\": { \"min\": 5000, \"max\": 10000 }\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/project/create-project-request", "host": [ "{{base_url}}" ], "path": [ "project", "create-project-request" ] }
					}
				},
				{
					"name": "Accept Project",
					"request": {
						"auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{access_token}}", "type": "string" } ] },
						"method": "PATCH",
						"url": { "raw": "{{base_url}}/project/accept-project/{{project_id}}", "host": [ "{{base_url}}" ], "path": [ "project", "accept-project", "{{project_id}}" ] }
					}
				}
			]
		},
		{
			"name": "Message",
			"item": [
				{
					"name": "Send Message",
					"request": {
						"auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{access_token}}", "type": "string" } ] },
						"method": "POST",
						"body": {
							"mode": "raw",
							"raw": "{\n    \"receiverId\": \"target_user_id\",\n    \"message\": \"Hello, I saw your project request.\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/message/send-message", "host": [ "{{base_url}}" ], "path": [ "message", "send-message" ] }
					}
				}
			]
		}
	],
	"variable": [
		{ "key": "base_url", "value": "http://localhost:3000/api/v1", "type": "string" },
		{ "key": "access_token", "value": "YOUR_JWT_TOKEN", "type": "string" },
		{ "key": "project_id", "value": "", "type": "string" }
	]
}
